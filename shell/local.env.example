# Copy this file to ~/.config/dotfiles/local.env and fill in local-only values.

# Secrets
export AI_CLAUDE_API_KEY=""
export AI_GOOGLE_API_KEY=""

# Local directories
export PROJECTS_DIR="$HOME/src"

# Optional colon-separated PATH additions for machine-specific tools.
export DOTFILES_EXTRA_PATHS="$HOME/.dotnet/tools:$HOME/.lmstudio/bin:$HOME/.elmera-config:$HOME/.antigravity/antigravity/bin"
