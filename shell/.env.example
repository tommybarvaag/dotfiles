# Copy this file to ~/.config/dotfiles/.env and fill in local-only values.

# Secrets
export AI_CLAUDE_API_KEY=""
export AI_GOOGLE_API_KEY=""

# Local directories
export PROJECTS_DIR="$HOME/src"

# Work git email for the `git iw` alias (init work repo).
export WORK_GIT_EMAIL=""

# Optional colon-separated PATH additions for machine-specific tools.
export DOTFILES_EXTRA_PATHS=""
